-- ========================================
-- agent.create().run() Agent 编排演示
-- ========================================

-- 1. 注册工具
let docs = ["AI入门指南", "机器学习基础", "深度学习实战"]

ai.tool("search", "搜索文档", "{\"type\":\"object\",\"properties\":{\"query\":{\"type\":\"string\"}}}", fn(args)
  print("  [tool] 搜索文档")
  return "搜索结果: " + docs.get(0) + ", " + docs.get(1)
end)

ai.tool("summarize", "总结文本", "{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\"}}}", fn(args)
  print("  [tool] 总结文本")
  return "总结: 这是一段关于 AI 的文档"
end)

ai.tool("save", "保存报告", "{\"type\":\"object\",\"properties\":{\"content\":{\"type\":\"string\"}}}", fn(args)
  print("  [tool] 保存报告")
  return "已保存到 report.txt"
end)

-- 2. 创建 Agent
let researcher = agent.create("researcher", {
  "tools": ["search", "summarize", "save"],
  "model": "deep",
  "max_steps": 10,
  "system": "你是一个研究助手。先搜索信息，再总结，最后保存报告。"
})

-- 3. 查看 Agent 信息
print("=== Agent 信息 ===")
print("名称: " + researcher.name())
print("最大步数: " + researcher.max_steps())

-- 4. 执行任务
print("")
print("=== 执行任务 ===")
print("（无 API Key 时走 mock 模式）")
let result = researcher.run("调研 AI 编程语言的发展趋势")
print("")
print("结果: " + result)
