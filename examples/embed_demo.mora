-- ============================================================
-- v11: 向量嵌入 + 相似度 + 语义检索端到端 demo
-- ============================================================
-- 运行：
--   - 无 API key：使用 mock 词袋 embedding（32 维），语义粗糙但可重现
--   - 有 OPENAI_API_KEY：使用真实 text-embedding-3-small（1536 维）
--
-- 演示范围：
--   1. ai.embed 单文本 / 批量 / 降维
--   2. ai.cosine / ai.dot / ai.euclidean / ai.norm
--   3. ai.search 语义检索
--   4. 错误处理（无 key / 类型错误）

task main()
  -- =========================================================
  -- [1] 单文本 embedding
  -- =========================================================
  print("=== [1] ai.embed single text ===")
  try
    let v = ai.embed("猫喜欢追老鼠")
    print("  vector length: " + v.len())
    print("  first 3 dims:  " + [v[0], v[1], v[2]])
  catch err
    print("  [no embed] " + err)
  end

  -- =========================================================
  -- [2] 批量 embedding
  -- =========================================================
  print("")
  print("=== [2] ai.embed batch ===")
  try
    let batch = ai.embed(["苹果", "香蕉", "汽车", "飞机"])
    print("  batch size:    " + batch.len())
    print("  first vec len: " + batch[0].len())
  catch err
    print("  [no embed] " + err)
  end

  -- =========================================================
  -- [3] 降维（v3 系列支持）
  -- =========================================================
  print("")
  print("=== [3] ai.embed with dimensions=64 ===")
  try
    let small = ai.embed("降维测试", 64)
    print("  reduced dim: " + small.len())
  catch err
    print("  [skip] " + err)
  end

  -- =========================================================
  -- [4] 相似度函数（不依赖 API key）
  -- =========================================================
  print("")
  print("=== [4] similarity functions (pure math) ===")
  let a: list = [1.0, 0.0, 0.0]
  let b: list = [1.0, 0.0, 0.0]    -- 与 a 完全相同
  let c: list = [0.0, 1.0, 0.0]    -- 与 a 正交
  let d: list = [-1.0, 0.0, 0.0]   -- 与 a 反向

  print("  cos(a, a) = " + ai.cosine(a, b))  -- 1.0
  print("  cos(a, c) = " + ai.cosine(a, c))  -- 0.0
  print("  cos(a, d) = " + ai.cosine(a, d))  -- -1.0
  print("  dot(a, b) = " + ai.dot(a, b))
  print("  dist(a, c) = " + ai.euclidean(a, c))
  print("  ||a|| = " + ai.norm(a))

  -- =========================================================
  -- [5] ai.search 语义检索
  -- =========================================================
  print("")
  print("=== [5] ai.search (top-3 from corpus) ===")
  let corpus = ["Python 是一门脚本语言", "Rust 注重内存安全", "今天的天气真好", "JavaScript 运行在浏览器", "编程语言有很多种", "我喜欢吃苹果"]
  let query = "我想学编程"
  print("  query: " + query)
  try
    let results = ai.search(query, corpus, 3)
    print("  results len: " + results.len())
    print("  top 3:")
    for r in results
      print("    [" + r.get("index") + "] score=" + r.get("score") + "  " + r.get("text"))
    end
  catch err
    print("  [no search] " + err)
  end

  -- =========================================================
  -- [6] 错误处理演示
  -- =========================================================
  print("")
  print("=== [6] error handling ===")
  try
    let _ = ai.cosine([1.0, 2.0], [1.0, 2.0, 3.0])  -- 维度不匹配
  catch err
    print("  caught: " + err)
  end

  try
    let _ = ai.search("query")  -- 缺 corpus
  catch err
    print("  caught: " + err)
  end

  print("")
  print("=== embed demo done ===")
end
