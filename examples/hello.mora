let topic = "AI workflow language"

task summarize(input)
  prompt = "Summarize this in 3 bullets: " + input
  result = ai.chat(prompt)
  return result
end

task main()
  text = web.fetch("https://example.com")
  summary = summarize(text)

  if summary != "" then
    print(summary)
  end

  print("Done")
end
