let config: dict = { model: "gpt-4", temperature: 0.7 }

export task summarize(input: string)
  prompt: string = "Summarize: {input}"
  return ai.chat(prompt)
end

task classify(input: string)
  let result = ai.chat("Classify: {input}")
  return match result with
    "positive" -> "Good"
    "negative" -> "Bad"
    _ -> "Neutral"
  end
end

task main()
  let urls: list = ["https://a.com", "https://b.com", "https://c.com"]

  -- 并发执行：同时抓取多个 URL
  let results = parallel
    web.fetch(urls[0])
    web.fetch(urls[1])
    web.fetch(urls[2])
  end

  print("Fetched " + len(results) + " pages")

  for text in results
    let summary = text |> summarize()
    print(summary)
  end

  let status = classify("Great product!")
  print("Status: " + status)

  let score: number = 85
  let grade = match score with
    90 -> "A"
    80 -> "B"
    70 -> "C"
    _ -> "F"
  end
  print("Grade: " + grade)

  let data = { name: "Mora", version: 6, features: ["parallel", "match", "types", "repl"] }
  let matched = match data with
    { name: n, version: v } -> "{n} v{v}"
    _ -> "Unknown"
  end
  print(matched)

  print("Done")
end
