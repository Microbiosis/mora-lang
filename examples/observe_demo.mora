-- v0.04 终态 Slice 3 demo: observe + span
-- 测: 启用 trace + 创建 span + 嵌套 span

-- 启用 trace
observe trace do
  -- body 是普通语句
  print("trace enabled")
end

-- 顶层 span
span "main_work" do
  print("inside main_work span")

  -- 嵌套 span
  span "sub_task" tags {key: "value"} do
    let who = "world"
    let r = p"hello {who}"
    print("sub_task result: " + r)
  end

  print("after sub_task")
end

print("done with observe/span demo")
