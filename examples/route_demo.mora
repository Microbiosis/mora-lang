-- v0.04 终态 Slice 2 demo: route + RouteCall
-- 测: route 块声明 + IDENT(p"...") 走 RouteCall

-- 声明 routes
route fast: "gpt-4o-mini"
route deep: "gpt-4o"
route code: "claude-3.5-sonnet"

-- 变量定义
let text = "Mora is an AI-native language"
let q = "Raft vs Paxos"

-- 直接用 RouteCall
let summary = fast(p"summarize: {text}")
print("summary: " + summary)

let analysis = deep(p"analyze deeply: {q}")
print("analysis: " + analysis)

-- 普通函数仍然工作 (不与 route 冲突)
print("regular print works")
