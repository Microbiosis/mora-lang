-- v0.04 终态 Slice 5 demo: serve as mcp + JSON Schema 自动生成
-- 测: tool(params): return → JSON Schema 自动生成

serve as mcp do
  -- Slice 5: tool 现在可以带 params, 自动生成 JSON Schema
  tool search(query: string, max_results: number): string do
    let q = args["query"]
    let n = args["max_results"]
    return "found " + n + " docs for: " + q
  end

  tool calculate(expression: string): number do
    return 42
  end
end

print("server blocks")
