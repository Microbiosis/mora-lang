-- v0.04 终态 Slice 3 综合 demo
-- 测: observe + span + HTTP server + route

route fast: "gpt-4o-mini"

-- 顶层启用 trace (在 serve 之前)
observe trace do
  -- 块内可放 setup
end

serve as http on port 3000 do
  GET "/health" -> fn(req)
    return {status: "ok"}
  end

  POST "/chat" -> fn(req)
    -- Slice 3: span 块嵌套在 handler 内
    span "user_chat" tags {path: "/chat"} do
      let user_text = req["body"]["text"]
      let answer = fast(p"answer: {user_text}")
      print("span finished, answer: " + answer)
    end
    -- Span 块没有 return, handler 必须显式 return
    let reply = fast(p"reply hi")
    return reply
  end

  GET "/traces" -> fn(req)
    return {spans: "see stderr"}
  end
end

print("server up")
