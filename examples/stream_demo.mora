-- ========================================
-- ai.stream 流式输出演示
-- ========================================
-- 无 API Key 时自动走 mock 模式，逐字符输出

print("=== 流式逐 token 打印 ===")
for token in ai.stream("写一首关于编程的短诗")
  print(token)
end

print("")
print("=== collect 收集完整结果 ===")
let result = ai.stream("你好世界").collect()
print("完整结果: " + result)

print("")
print("=== is_done 检查 ===")
let s = ai.stream("测试")
print("创建后 is_done: " + s.is_done())
let _ = s.collect()
print("collect 后 is_done: " + s.is_done())
